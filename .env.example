# ArdenLeaf Environment Variables Configuration Example
# Copy this file to .env and fill in the actual values

# Flask Secret Key
SECRET_KEY=your-secret-key-here

# MySQL Configuration
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=your-mysql-password
MYSQL_DB=ardenleaf
MYSQL_PORT=3306

# Railway note:
# Railway's MySQL service also provides MYSQLHOST / MYSQLUSER / MYSQLPASSWORD /
# MYSQLDATABASE / MYSQLPORT automatically. The app supports both naming styles.
